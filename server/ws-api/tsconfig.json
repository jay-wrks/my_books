{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["../node_modules/@types"],
    "paths": { "@shared/*": ["../shared/*"] }
  },
  "include": ["./**/*.ts", "../shared/**/*.ts"]
}
